<?xml version="1.0"?>
<!--
  Lab 4 worksheet : 2-DoF manipulator URDF (ex_robot1)

  Open the Lab 4 slides and fill in the TODO blocks below.

  Pre-class TODOs (Section 4.2 ~ 4.4):
    TODO 1 : world link + fixed joint        (slide p8, left panel)
    TODO 2 : joint1 + link1                  (slide p8, right panel)
    TODO 3 : ros_control gazebo plugin       (slide p24)
    TODO 4 : transmission tran1              (slide p25)

  In-Class Assignment (slide p37):
    TODO 5 : joint2 + link2                  (extend manipulator to 2-DoF)
    TODO 6 : transmission tran2              (for joint2)
-->
<robot name="ex_robot1">

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="12"/>
            <inertia ixx="2.0" ixy="0.0" ixz="0.0"
                     iyy="2.0" iyz="0.0"
                     izz="2.0"/>
        </inertial>
    </link>


    <!-- ============================================================ -->
    <!-- TODO 1 : world link + fixed joint     (slide p8, left panel)  -->
    <!--                                                                -->
    <!-- Hint:                                                          -->
    <!--   - Define an empty link named "world".                       -->
    <!--   - Define a fixed joint with parent="world", child="base_link". -->
    <!--   - Lift base_link by half its height (origin xyz="0 0 0.5"). -->
    <!-- ============================================================ -->



    <!-- ============================================================ -->
    <!-- TODO 2 : joint1 + link1               (slide p8, right panel) -->
    <!--                                                                -->
    <!-- Hint:                                                          -->
    <!--   - joint1 type = "continuous" (rotates around y axis).       -->
    <!--   - parent: base_link, child: link1                           -->
    <!--   - joint1 origin xyz="0 0 0.5" (top of base_link).           -->
    <!--   - axis xyz="0 1 0", dynamics damping="0.7".                 -->
    <!--                                                                -->
    <!--   - link1 is a tall box, size="0.3 0.3 3".                    -->
    <!--   - visual / collision / inertial origin xyz="0 0 1.5"        -->
    <!--     so the box is centered along its own length.              -->
    <!--   - mass = 3.                                                  -->
    <!--   - Solid box inertia: I = (1/12) * m * (a^2 + b^2)           -->
    <!--       ixx = iyy = (1/12) * 3 * (0.3^2 + 3.0^2) = 2.2725       -->
    <!--       izz       = (1/12) * 3 * (0.3^2 + 0.3^2) = 0.045        -->
    <!--                                                                -->
    <!--   IMPORTANT: Gazebo silently REMOVES any link without an      -->
    <!--   <inertial> block, so do not forget it.                      -->
    <!-- ============================================================ -->



    <!-- ============================================================ -->
    <!-- TODO 3 : ros_control gazebo plugin    (slide p24)             -->
    <!--                                                                -->
    <!-- Hint:                                                          -->
    <!--   - Add a <gazebo> ... </gazebo> block.                       -->
    <!--   - Inside, add a <plugin> with                               -->
    <!--       name     = "gazebo_ros_control"                         -->
    <!--       filename = "libgazebo_ros_control.so"                   -->
    <!--   - Use <robotNamespace>/ex_robot1</robotNamespace>           -->
    <!--     so all controllers live under the /ex_robot1 namespace.   -->
    <!-- ============================================================ -->



