<?xml version="1.0"?>
<!--
  Lab 4: 1-DoF manipulator URDF (ex_robot1)

  Pre-class TODOs 1-4 are completed:
    - world link + fixed joint (slide p8)
    - joint1 + link1 with inertial (slide p8)
    - gazebo_ros_control plugin (slide p24)
    - transmission tran1 (slide p25)

  In-Class Assignment (TODO 5-6): extend to 2-DoF by adding joint2 + link2 + tran2.
-->
<robot name="ex_robot1">

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="12"/>
            <inertia ixx="2.0" ixy="0.0" ixz="0.0"
                     iyy="2.0" iyz="0.0"
                     izz="2.0"/>
        </inertial>
    </link>

    <!-- world link + fixed joint (slide p8) -->
    <link name="world"/>

    <joint name="fixed" type="fixed">
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
        <parent link="world"/>
        <child link="base_link"/>
    </joint>


    <!-- joint1 + link1 (slide p8) -->
    <joint name="joint1" type="continuous">
        <parent link="base_link"/>
        <child link="link1"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.7"/>
    </joint>

    <link name="link1">
        <visual>
            <origin xyz="0 0 1.5" rpy="0 0 0"/>
            <geometry>
                <box size="0.3 0.3 3"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 1.5" rpy="0 0 0"/>
            <geometry>
                <box size="0.3 0.3 3"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 1.5" rpy="0 0 0"/>
            <mass value="3"/>
            <inertia ixx="2.2725" ixy="0.0" ixz="0.0"
                     iyy="2.2725" iyz="0.0"
                     izz="0.045"/>
        </inertial>
    </link>


    <!-- gazebo_ros_control plugin (slide p24) -->
    <gazebo>
        <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
            <robotNamespace>/ex_robot1</robotNamespace>
            <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
        </plugin>
    </gazebo>


    <!-- transmission tran1 (slide p25) -->
    <transmission name="tran1">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="joint1">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor1">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>


</robot>
